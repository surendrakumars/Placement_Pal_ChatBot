# Hugging Face option
# Use either HF_TOKEN or HF_API_TOKEN. Keep the real token only in your local .env file.
HF_TOKEN=your_huggingface_token_here
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_PROVIDER=auto
HF_MAX_TOKENS=1600
# Optional: set HF_API_URL only if you want to use the legacy raw inference endpoint.
# HF_API_URL=https://api-inference.huggingface.co/models/meta-llama/Llama-3.1-8B-Instruct

# OpenAI option
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Local Ollama option
# USE_OLLAMA=1
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_URL=http://127.0.0.1:11434/api/generate

# App option
PORT=5000
